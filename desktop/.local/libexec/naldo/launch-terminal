#!/usr/bin/env bash

set -Eeuo pipefail

usage() {
  printf 'Usage: %s --terminal COMMAND --app-id APP_ID [--hold] [--] [COMMAND [ARG ...]]\n' "${0##*/}" >&2
}

terminal=""
app_id=""
hold=false

while (( $# > 0 )); do
  case "$1" in
  --terminal)
    if (( $# < 2 )) || [[ -z "$2" ]]; then
      usage
      exit 2
    fi
    terminal="$2"
    shift 2
    ;;
  --app-id)
    if (( $# < 2 )) || [[ -z "$2" ]]; then
      usage
      exit 2
    fi
    app_id="$2"
    shift 2
    ;;
  --hold)
    hold=true
    shift
    ;;
  --)
    shift
    break
    ;;
  *)
    usage
    exit 2
    ;;
  esac
done

if [[ -z "$terminal" || -z "$app_id" ]]; then
  usage
  exit 2
fi

terminal_args=("$terminal" "--class=$app_id")
if [[ "$hold" == true ]]; then
  terminal_args+=(--wait-after-command)
fi
if (( $# > 0 )); then
  terminal_args+=(-e "$@")
fi

# A UWSM-managed compositor has an active wayland-wm@….service. Niri's
# niri-session also activates graphical-session.target, so `uwsm check
# is-active` alone cannot distinguish the two session types.
if command -v uwsm >/dev/null 2>&1 &&
  command -v systemctl >/dev/null 2>&1 &&
  systemctl --user --quiet is-active 'wayland-wm@*.service'; then
  exec uwsm app -- "${terminal_args[@]}"
fi

# Niri already starts applications in app-niri scopes; launching directly keeps
# the process inside that session rather than incorrectly routing it through UWSM.
exec "${terminal_args[@]}"
