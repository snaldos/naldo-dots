#!/usr/bin/env python3
"""Reject likely plaintext credentials in a Git index without printing values."""

from __future__ import annotations

import re
import subprocess
import sys
from collections import defaultdict

MAX_TEXT_BLOB_BYTES = 4 * 1024 * 1024

TOKEN_PATTERNS = (
    (
        "private key",
        re.compile(rb"-----BEGIN (?:RSA |EC |OPENSSH )?PRIVATE KEY-----"),
    ),
    ("Google OAuth access token", re.compile(rb"\bya29\.[A-Za-z0-9._-]+")),
    ("Google OAuth refresh token", re.compile(rb"\b1//[A-Za-z0-9._-]+")),
    (
        "GitHub token",
        re.compile(
            rb"\b(?:gh[pousr]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,})\b"
        ),
    ),
    ("provider API token", re.compile(rb"\bsk-[A-Za-z0-9_-]{16,}\b")),
    ("Google API key", re.compile(rb"\bAIza[A-Za-z0-9_-]{20,}\b")),
    ("AWS access key", re.compile(rb"\b(?:AKIA|ASIA)[A-Z0-9]{16}\b")),
)

CREDENTIAL_ASSIGNMENT = re.compile(
    rb"""(?imx)
    ^\s*(?:export\s+)?["']?
    (?P<key>
        [A-Za-z0-9_.-]*
        (?:
            api[_-]?key
            | access[_-]?token
            | refresh[_-]?token
            | auth[_-]?token
            | client[_-]?secret
            | password
            | passwd
            | secret
        )
    )
    ["']?\s*[=:]\s*
    (?P<value>
        "(?:\\.|[^"\r\n])*"
        | '(?:\\.|[^'\r\n])*'
        | [^\s,\#}\r\n]+
    )
    """
)

PLACEHOLDERS = {
    b"",
    b"...",
    b"changeme",
    b"change-me",
    b"example",
    b"example-key",
    b"placeholder",
    b"redacted",
    b"test-placeholder",
    b"your-key-here",
    b"<redacted>",
    b"<secret>",
}
REFERENCE_VALUES = re.compile(
    rb"""(?ix)^(?:
        \$\{?[A-Z_][A-Z0-9_]*\}?
        | \{\{.*\}\}
        | (?:env|keyring|op|secret|vault)[:(\/].*
    )$"""
)


def git(repository: str, *arguments: str) -> bytes:
    return subprocess.run(
        ["git", "-C", repository, *arguments],
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    ).stdout


def line_number(data: bytes, offset: int) -> int:
    return data.count(b"\n", 0, offset) + 1


def normalized_assignment_value(value: bytes) -> bytes:
    value = value.strip()
    if len(value) >= 2 and value[:1] == value[-1:] and value[:1] in {b'"', b"'"}:
        value = value[1:-1].strip()
    return value


def findings_for(data: bytes) -> set[tuple[int, str]]:
    findings: set[tuple[int, str]] = set()

    for label, pattern in TOKEN_PATTERNS:
        for match in pattern.finditer(data):
            findings.add((line_number(data, match.start()), label))

    for match in CREDENTIAL_ASSIGNMENT.finditer(data):
        value = normalized_assignment_value(match.group("value"))
        if value.lower() in PLACEHOLDERS or value.lower() in {b"false", b"null", b"none"}:
            continue
        if REFERENCE_VALUES.fullmatch(value):
            continue
        findings.add((line_number(data, match.start()), "credential assignment"))

    return findings


def index_blobs(repository: str):
    entries = git(repository, "ls-files", "--stage", "-z")
    for entry in entries.split(b"\0"):
        if not entry:
            continue
        metadata, path = entry.split(b"\t", 1)
        mode, object_id, stage = metadata.split(b" ")
        if stage != b"0":
            raise RuntimeError("Git index contains unresolved entries")
        if mode not in {b"100644", b"100755"}:
            continue

        size = int(git(repository, "cat-file", "-s", object_id.decode("ascii")))
        if size > MAX_TEXT_BLOB_BYTES:
            continue
        data = git(repository, "cat-file", "blob", object_id.decode("ascii"))
        if b"\0" in data:
            continue
        yield path.decode("utf-8", errors="backslashreplace"), data


def main() -> int:
    repository = sys.argv[1] if len(sys.argv) == 2 else "."
    if len(sys.argv) > 2:
        print(f"Usage: {sys.argv[0]} [REPOSITORY]", file=sys.stderr)
        return 2

    try:
        git(repository, "rev-parse", "--is-inside-work-tree")
        unsafe: dict[str, set[tuple[int, str]]] = defaultdict(set)
        for path, data in index_blobs(repository):
            findings = findings_for(data)
            if findings:
                unsafe[path].update(findings)
    except (OSError, RuntimeError, subprocess.CalledProcessError, ValueError) as error:
        print(f"Credential guard could not inspect the Git index: {error}", file=sys.stderr)
        return 2

    if not unsafe:
        return 0

    print(
        "Credential-like content found in public repository index; refusing to commit:",
        file=sys.stderr,
    )
    for path in sorted(unsafe):
        details = ", ".join(
            f"line {line} ({label})" for line, label in sorted(unsafe[path])
        )
        print(f"  {path}: {details}", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
